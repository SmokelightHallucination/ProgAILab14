# Build artifacts
/collector/collector
/collector/*.exe
/validator/target/
*.a
*.so
*.dll
*.dylib
*.lib

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/

# Data / outputs (generated at runtime)
/data/*.parquet
/data/*.json
/data/*.jsonl
# Interactive HTML figures are regenerated; committed PNGs illustrate the README.
/docs/figures/*.html

# Editor / OS / local agent
.idea/
.vscode/
.claude/
.DS_Store
_pdf_text.txt

# Keep placeholder dirs
!/data/.gitkeep
!/docs/figures/.gitkeep
